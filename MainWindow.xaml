<Window x:Class="MusicForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MusicForge" Height="600" Width="900"
        Background="#1e1e1e" Foreground="#e0e0e0"
        FontFamily="Consolas">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
            <Button x:Name="PlayButton" Content="Play" Padding="14,6" Margin="0,0,8,0" Click="PlayButton_Click"/>
            <Button x:Name="StopButton" Content="Stop" Padding="14,6" Margin="0,0,8,0" Click="StopButton_Click"/>
            <TextBlock Text="Example:" VerticalAlignment="Center" Margin="16,0,8,0"/>
            <ComboBox x:Name="ExamplesCombo" MinWidth="220" SelectionChanged="ExamplesCombo_SelectionChanged"/>
        </StackPanel>

        <TextBox x:Name="CodeBox" Grid.Row="1"
                 Margin="8,0,8,0"
                 AcceptsReturn="True" AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontSize="14"
                 Background="#252526" Foreground="#dcdcdc"/>

        <TextBlock x:Name="StatusBar" Grid.Row="2" Margin="10,6,8,8"
                   Foreground="#9cdcfe" Text="Ready"/>
    </Grid>
</Window>
